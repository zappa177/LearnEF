@model IEnumerable<PersonResponse>
@{
    Layout = null;
}
<link href="@("http://"+Context.Request.Host.ToString()+"/css/StyleSheet.css")" rel="stylesheet" />
   <h1>Person</h1>
    <table class="table w-100 mt">
        <thead>
            <tr>
                <th>Person Name</th>
                <th>Email</th>
                <th>DateOfBirth</th>
                <th>Age</th>
                <th>Gender</th>
                <th>Country</th>
                <th>Address</th>
                <th>Receiver New Letter</th>
            </tr>
        </thead>
        <tbody>
            @foreach (PersonResponse person in Model)
            {
                <tr>
                    <td style="width: 15%;">@person.PersonName</td>
                    <td style="width: 20%;">@person.Email</td>
                    <td style="width: 13%;">@person.DateOfBirth?.ToString("dd-MM-yyyy")</td>
                    <td style="width: 9%;">@person.Age</td>
                    <td style="width: 9%;">@person.Gender</td>
                    <td style="width: 10%;">@person.Country</td>
                    <td style="width: 15%;">@person.Address</td>
                    <td style="width: 20%;">@person.ReceiverNewsletter</td>                  
                </tr>
            }
        </tbody>
    </table>
