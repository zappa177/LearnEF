@{
    ViewBag.Title = "Create Person";
}

<a href="~/person/index" class="link-hover">Back to List</a>
<h2>Create Person</h2>
<div class="w-50">
    <form action="~/person/create" method="post">
        @* personname   *@
        <div class="form-field flex">
            <div class="flex-1">
                <label for="PersonName" class="form-label pt">Person Name</label>
            </div>
            <div class="flex-1">
                <input type="text" id="PersonName" name="PersonName" class="form-input"/>
            </div>
        </div>
        @* Email *@
        <div class="form-field flex">
            <div class="flex-1">
                <label for="Email" class="form-label pt">Email</label>
            </div>
            <div class="flex-1">
                <input type="email" id="Email" name="Email" class="form-input" />
            </div>
        </div>
            @* Date of birth *@
        <div class="form-field flex">
            <div class="flex-1">
                <label for="DateOfBirth" class="form-label pt">Date of Birth</label>
            </div>
            <div class="flex-1">
                <input type="date" id="DateOfBirth" name="DateOfBirth" class="form-input" />
            </div>
        </div>
        @* Gender *@
        <div class="form-field flex">
            <div class="flex-1">
                <label class="form-label pt">Gender</label>
            </div>
            <div class="flex-1 flex">
                <input type="radio" id="Male" name="Gender" value="Male" class="form-input" />
                <label for="Male" class="form-label">Male</label>
                <input type="radio" id="Female" name="Gender" value="Female" class="form-input" />
                <label for="Female" class="form-label">Female</label>
                <input type="radio" id="Other" name="Gender" value="Other" class="form-input" />
                <label for="Other" class="form-label">Other</label>
            </div>
        </div>
        @* Country *@
        <div class="form-field flex">
            <div class="flex-1">
                <label for="CountryID" class="form-label pt">Country</label>
            </div>
            <div class="flex-1">
                <select name="CountryID" id="CountryID" class="form-input">
                    <option value="">Select a country</option>
                    @foreach (CountryResponse country in ViewBag.Countries)
                    {
                        <option value="@country.CountryID">@country.CountryName</option>
                    }
                    )
                </select>
            </div>
        </div>
        @* Address *@
        <div class="form-field flex">
            <div class="flex-1">
                <label for="Address" class="form-label pt">Address</label>
            </div>
            <div class="flex-1">
                <textarea type="text" id="Address" name="Address" class="form-input" ></textarea>
            </div>
        </div>
        @*Receive Newsletters*@
        <div class="form-field">
            <div class="flex-1">
                <input type="checkbox" id="ReceiveNewsletters" name="ReceiveNewsletters" class="form-input" value="true" />
                <label for="ReceiveNewsletters" class="form-label">Receive Newsletters</label>
            </div>
        </div>
        @*Submit Button*@
        <div class="form-field flex">
            <div class="flex-1">
                <button type="submit" class="button button-blue-back">Create</button>
                @if (ViewBag.Error != null)
                {
                    <div class="text-red ml">
                        <ul>
                            @foreach (string error in ViewBag.Error)
                            {
                                <li class="ml">@error</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </form>
</div>