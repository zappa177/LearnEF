@{
    ViewBag.Title = "Edit Person";
}
@model PersonUpdateRequest

<a href="~/person/index" class="link-hover">Back to List</a>
<h2>Edit Person</h2>
<div class="w-50 center-box">
    <form asp-controller="Person" asp-action="Edit" method="post">
        <input type="hidden" asp-for="PersonID" />
        @* personname   *@
        <div class="form-field flex">
            <div class="flex-1">
                <label asp-for="PersonName" class="form-label pt">Person Name</label>
            </div>
            <div class="flex-1">
                <input asp-for="PersonName" type="text" class="form-input"/>
                @* <span asp-validation-for="PersonName"></span> *@
            </div>
        </div>
        @* Email *@
        <div class="form-field flex">
            <div class="flex-1">
                <label asp-for="Email" class="form-label pt">Email</label>
            </div>
            <div class="flex-1">
                <input asp-for="Email" type="email" class="form-input" />
                @* <span asp-validation-for="Email" class="text-red"></span> *@
            </div>
        </div>
            @* Date of birth *@
        <div class="form-field flex">
            <div class="flex-1">
                <label asp-for="DateOfBirth" class="form-label pt">Date of Birth</label>
            </div>
            <div class="flex-1">
                <input type="date" asp-for="DateOfBirth" class="form-input" />
            </div>
        </div>
        @* Gender *@
        <div class="form-field flex">
            <div class="flex-1">
                <label class="form-label pt">Gender</label>
            </div>
            <div class="flex-1 flex ml">
                @{
                    string[] genders = (string[])Enum.GetNames(typeof(GenderOption));
                }
                    @foreach(string gender in genders)
                    {
                        <input type="radio" asp-for="Gender" value="@gender" class="ml"/>
                        <label for="@gender" class="ml">@gender</label>
                    }
             </div>
        </div>
        @* Country *@
        <div class="form-field flex">
            <div class="flex-1">
                <label for="CountryID" class="form-label pt">Country</label>
            </div>
            <div class="flex-1">
                <select asp-for="CountryID" class="form-input" asp-items="@ViewBag.Countries">
                    <option value="">Select a country</option>
                    @* @foreach (CountryResponse country in ViewBag.Countries)
                    {
                        <option value="@country.CountryID">@country.CountryName</option>
                    }
                    ) *@
                </select>
            </div>
        </div>
        @* Address *@
        <div class="form-field flex">
            <div class="flex-1">
                <label for="Address" class="form-label pt">Address</label>
            </div>
            <div class="flex-1">
                <textarea asp-for="Address" class="form-input"></textarea>
            </div>
        </div>
        @*Receive Newsletters*@
        <div class="form-field">
            <div class="flex-1">
                <input type="checkbox"  asp-for="ReceiverNewsletter" class="form-input" />
                <label for="ReceiveNewsletters" class="form-label">Receive Newsletters</label>
            </div>
        </div>
        @*Submit Button*@
        <div class="form-field flex">
            <div class="flex-1">
                <button type="submit" class="button button-blue-back">Update</button>
                @if (ViewBag.Error != null)
                {
                    <div class="text-red ml">
                        <ul>
                            @foreach (string error in ViewBag.Error)
                            {
                                <li class="ml">@error</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </form>
</div>
